{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(aws * delete*)",
      "Bash(aws * terminate*)",
      "Bash(aws s3 rm:*)",
      "Bash(aws s3 rb:*)",
      "Bash(aws iam create*)",
      "Bash(aws iam attach*)",
      "Bash(aws iam put*)",
      "Bash(aws iam update*)",
      "Bash(aws iam delete*)",
      "Bash(terraform destroy*)",
      "Bash(terraform force-unlock:*)",
      "Read(~/.ssh/id_*)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "ask": [
      "Bash(rm:*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/work",
      "~/dotfiles",
      "~/notes",
      "/tmp"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); if [[ \"$file\" == *.tf ]]; then dir=$(dirname \"$file\"); terraform fmt \"$dir\" && (cd \"$dir\" && terraform validate); fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); if [[ \"$file\" == *.md ]]; then prettier --write \"$file\"; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"continue\": false, \"stopReason\": \"Auto-compaction blocked. Run /compact manually if you want to proceed.\"}'",
            "statusMessage": "Checking compaction..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "msg=$(jq -r '.message // empty'); if [ -n \"$msg\" ] && [ \"$msg\" != \"Claude is waiting for your input\" ] && [ -x \"$HOME/.local/bin/claude-slack-send\" ]; then \"$HOME/.local/bin/claude-slack-send\" \"$msg\" >/dev/null 2>&1; fi"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "theme": "dark-ansi",
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "model": "opus"
}
